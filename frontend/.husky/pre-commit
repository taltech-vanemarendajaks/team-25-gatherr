cd frontend

echo "🚀 Checking for API schema changes..."

# Try to fetch latest schema from running backend (optional - skipped if backend is not running)
npm run generate:schema && echo "Schema fetched from backend" || echo "Backend not running, using existing schema.json"

# Regenerate types from schema.json
npm run generate:types && echo "TypeScript types updated"
git add schema.json src/api/types.gen.ts

# Linting/formatting
echo "🧼 Running linting and formatting..."
npm run lint-staged
